{
  "name": "tronche",
  "description": "Tronche generates custom, SVG-based avatars from any username and color palette. Vue.js/Nuxt.js library with a free API tier.",
  "homepage": "https://github.com/rootasjey/tronche",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rootasjey/tronche"
  },
  "bugs": {
    "url": "https://github.com/rootasjey/tronche/issues"
  },
  "keywords": [
    "avatar",
    "gravatar",
    "profile picture",
    "user avatar",
    "avatar generator",
    "avatar placeholder",
    "vue",
    "nuxt",
    "vue3",
    "nuxt3",
    "tronche"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./module": {
      "types": "./dist/module.d.ts",
      "import": "./dist/module.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/*"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "vite build --config vite.lib.config.ts && vite build --config vite.vue.config.ts && cp src/vue/tronche-vue.d.ts dist/vue/index.d.ts && vite build --config vite.react.config.ts && cp src/react/tronche-react.d.ts dist/react/index.d.ts && tsc --p ./tsconfig.module.json",
    "build:demo": "nuxt build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "attw --pack .",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "postinstall": "nuxt prepare",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "nuxt": ">=3.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "vue": ">=3.0.0"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.8"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@iconify-json/lucide": "^1.2.102",
    "@iconify-json/radix-icons": "^1.2.6",
    "@iconify-json/tabler": "^1.2.33",
    "@libsql/client": "^0.17.4",
    "@noble/hashes": "^2.2.0",
    "@nuxt/devtools": "latest",
    "@nuxt/eslint-config": "^0.2.0",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxthub/core": "^0.10.7",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.1.0",
    "@types/react": "^19.2.17",
    "@una-ui/nuxt": "^1.0.0-alpha.17",
    "@unocss/nuxt": "^66.7.4",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^13.0.0",
    "@vue/test-utils": "^2.4.11",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.20.1",
    "globals": "^16.2.0",
    "jsdom": "^29.1.1",
    "nice-color-palettes": "^4.0.0",
    "nuxt": "^4.4.8",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-i18n-micro": "^3.21.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "semantic-release": "^24.2.9",
    "shiki": "^4.3.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.10",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0",
    "wrangler": "^4.106.0"
  }
}
