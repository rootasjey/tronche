{
  "name": "tronche",
  "description": "Tronche generates custom, SVG-based avatars from any username and color palette. Vue.js/Nuxt.js library with a free API tier.",
  "homepage": "https://github.com/rootasjey/tronche",
  "version": "0.2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rootasjey/tronche"
  },
  "bugs": {
    "url": "https://github.com/rootasjey/tronche/issues"
  },
  "keywords": [
    "avatar",
    "gravatar",
    "profile picture",
    "user avatar",
    "avatar generator",
    "avatar placeholder",
    "vue",
    "nuxt",
    "vue3",
    "nuxt3",
    "tronche"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/module.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./module": {
      "types": "./dist/module.d.ts",
      "import": "./dist/module.js"
    },
    "./runtime/*": {
      "import": "./dist/runtime/*"
    }
  },
  "files": [
    "dist/*"
  ],
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "tsc --p ./tsconfig.lib.json && vite build --config vite.lib.config.ts && tsc --p ./tsconfig.module.json && cp -r src/runtime dist/runtime",
    "build:demo": "nuxt build",
    "lint": "eslint .",
    "preview": "nuxt preview",
    "generate": "nuxt generate",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "postinstall": "nuxt prepare"
  },
  "peerDependencies": {
    "nuxt": ">=3.0.0",
    "vue": ">=3.0.0"
  },
  "dependencies": {
    "@libsql/client": "^0.17.4",
    "@noble/hashes": "^2.2.0",
    "@nuxthub/core": "^0.10.7",
    "@una-ui/nuxt": "^1.0.0-alpha.17",
    "drizzle-orm": "^0.45.2",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-i18n-micro": "^3.21.2",
    "shiki": "^4.3.1"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.102",
    "@iconify-json/radix-icons": "^1.2.6",
    "@iconify-json/tabler": "^1.2.33",
    "@nuxt/devtools": "latest",
    "@nuxt/eslint-config": "^0.2.0",
    "@types/node": "^24.1.0",
    "@unocss/nuxt": "^66.7.4",
    "@vue/eslint-config-typescript": "^13.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.20.1",
    "globals": "^16.2.0",
    "nice-color-palettes": "^4.0.0",
    "nuxt": "^4.4.8",
    "typescript": "~5.8.3",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0",
    "wrangler": "^4.106.0"
  }
}
