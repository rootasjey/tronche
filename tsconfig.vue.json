{
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "dist/vue",
    "emitDeclarationOnly": false,
    "outDir": "dist/vue",
    "rootDir": "src",
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "jsx": "preserve",
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/vue"]
}
